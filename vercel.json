{
  "buildCommand": "cd mobile && npm ci && npm run build",
  "outputDirectory": "mobile/dist",
  "framework": null,
  "installCommand": "cd mobile && npm ci",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)\\.wasm",
      "headers": [{ "key": "Content-Type", "value": "application/wasm" }]
    }
  ]
}
