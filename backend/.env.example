# Copy to .env and fill in. Never commit .env.
# Local walkthrough: docs/RUNNING.md

# --- Local dev (defaults) ---
SLEEPSYNC_DB_PATH=./data/sleepsync.db
# SLEEPSYNC_ENV=development

# --- Hosted production (Railway) ---
# SLEEPSYNC_ENV=production
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_JWT_SECRET=

# Google OAuth — Web application client in Cloud Console (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Must match an Authorized redirect URI in Google Cloud exactly.
# Local dev (uvicorn on 127.0.0.1:8000):
GOOGLE_HEALTH_REDIRECT_URI=http://127.0.0.1:8000/v1/google-health/oauth/callback
# Railway production:
# GOOGLE_HEALTH_REDIRECT_URI=https://your-api.up.railway.app/v1/google-health/oauth/callback

# Where the browser lands after the backend exchanges the code (not registered in Google Cloud).
# Expo web local:
GOOGLE_HEALTH_APP_RETURN_URI=http://localhost:8081/google-health/callback
# Vercel production:
# GOOGLE_HEALTH_APP_RETURN_URI=https://your-app.vercel.app/google-health/callback
# Native deep link:
# GOOGLE_HEALTH_APP_RETURN_URI=sleepsync://google-health/callback

# Encrypt OAuth tokens at rest (required when Google OAuth client id/secret are set):
TOKEN_ENCRYPTION_KEY=

# Leave Google OAuth empty to disable Connect Google Health (plan uses mock sleep week).
