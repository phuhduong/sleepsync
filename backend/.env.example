# Copy to .env and fill in. Never commit .env.
# Full walkthrough: docs/GOOGLE_HEALTH.md

# Local SQLite (nights, feature sets, Google Health tokens)
SLEEPSYNC_DB_PATH=./data/sleepsync.db

# Google OAuth — Web application client in Cloud Console (secrets stay on the server)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Must match an Authorized redirect URI in Google Cloud exactly.
# Local dev (uvicorn on 127.0.0.1:8000):
GOOGLE_HEALTH_REDIRECT_URI=http://127.0.0.1:8000/v1/google-health/oauth/callback
# Hosted / ngrok example:
# GOOGLE_HEALTH_REDIRECT_URI=https://your-api.example.com/v1/google-health/oauth/callback

# Where the browser lands after the backend exchanges the code (not registered in Google Cloud).
# Expo web local:
GOOGLE_HEALTH_APP_RETURN_URI=http://localhost:8081/google-health/callback
# Native deep link:
# GOOGLE_HEALTH_APP_RETURN_URI=sleepsync://google-health/callback

# Encrypt refresh tokens at rest: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Leave client id/secret empty to disable Connect Google Health (tonight's plan still uses mock sleep week).
