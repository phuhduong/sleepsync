# Copy to .env and fill in. Never commit .env.

# Local SQLite (nights, feature sets, Google Health tokens)
SLEEPSYNC_DB_PATH=./data/sleepsync.db

# Google OAuth — Web server client in Cloud Console
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Must match Authorized redirect URIs (https only)
GOOGLE_HEALTH_REDIRECT_URI=https://your-api.example.com/v1/google-health/oauth/callback

# Deep link after connect (match Expo app scheme in app.json)
GOOGLE_HEALTH_APP_RETURN_URI=sleepsync://google-health/callback

# Encrypt refresh tokens at rest (any long random string for self-hosted demo)
TOKEN_ENCRYPTION_KEY=

# Optional: force synthetic data even when OAuth client is set
# GOOGLE_HEALTH_SANDBOX=1
