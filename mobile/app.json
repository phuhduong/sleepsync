{
  "expo": {
    "name": "sleepsync",
    "slug": "sleepsync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sleepsync",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phuhduong.sleepsync"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "react-native-ble-plx",
        {
          "bluetoothAlwaysPermission": "SleepSync connects to your melatonin patch to deliver tonight's profile.",
          "neverForLocation": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
