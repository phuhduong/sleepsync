# Copy to .env.local (or .env). Restart Expo / redeploy Vercel after changes.
# Local walkthrough: docs/RUNNING.md

# --- Local dev ---
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# --- Hosted production (Vercel) ---
# EXPO_PUBLIC_API_URL=https://your-api.up.railway.app
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Health: configure backend OAuth per docs/GOOGLE_HEALTH.md
# EXPO_PUBLIC_GOOGLE_HEALTH_ENABLED=0

# ESP32 BLE patch (optional) — see docs/BLE_PATCH.md
# EXPO_PUBLIC_BLE_ENABLED=1
