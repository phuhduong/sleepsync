# Copy to .env.local (or .env). Restart Expo after changes.

# Python API (use LAN IP on a physical device, not localhost)
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Live Google Health: configure backend OAuth per docs/GOOGLE_HEALTH.md

# Set to 0 to hide Connect Google Health UI
# EXPO_PUBLIC_GOOGLE_HEALTH_ENABLED=1

# Optional ESP / mock pump
# EXPO_PUBLIC_PATCH_URL=
